#!/usr/bin/env bun

import { homedir } from "node:os";
import { join, resolve } from "node:path";
import { ThatchDB } from "../src/db";
import { detectRepo } from "../src/git";
import { BgeEmbeddingModel } from "../src/embeddings";
import { hygieneReport } from "../src/hygiene";
import { claudeSessionStartReminder } from "../src/prompts";
import { setupClaudeCode, setupCursor } from "../src/setup";

const configHome = process.env.XDG_CONFIG_HOME ?? join(homedir(), ".config");
const dbPath = process.env.THATCH_DB_PATH ?? join(configHome, "thatch", "thatch.db");
const db = new ThatchDB(dbPath);

const [command, ...args] = process.argv.slice(2);

function usage(): never {
  console.error(`USAGE
  thatch stores                    List all stores
  thatch list   [store]            List memory labels in a store  
  thatch show   <label> [store]    Display a memory by label
  thatch forget <label> [store]    Remove a memory by label
  thatch search <query> [store]    Semantic search (cosine similarity)
  thatch mcp                       Start the stdio MCP server (for Claude Code, Cursor, etc.)
  thatch reminder [--json]         Print session-start reminder (for SessionStart hook)
  thatch hygiene                   Print the hygiene report (standalone)
  thatch prime                     Prime project memory (runs the primer skill via opencode, cursor, or claude)
  thatch buffer-batch              Append a PostToolBatch payload to the queue (Claude Code hook only)
  thatch buffer-tool               Append a single postToolUse interaction to the queue (Cursor hook only)
  thatch flush-tools [--json]      Peek the queue + print an extraction nudge (hook only)
  thatch flush-predictions [--json] Query predictions for the prompt (hook only)
  thatch setup --claude [--cursor] [--global]
                                   Install config + instructions + hooks + skills

Stores default to the repo detected from git remote. Use "global" for the
global store. Use "all" with search to search project + global together.`);
  process.exit(1);
}

async function defaultStore(): Promise<string> {
  try {
    return await detectRepo();
  } catch {
    return "unknown";
  }
}

/** Resolve the project directory from host-specific env vars or cwd. */
function projectDir(): string {
  return process.env.CURSOR_PROJECT_DIR ?? process.env.CLAUDE_PROJECT_DIR ?? process.cwd();
}

switch (command) {
  case "stores":
    console.log(db.listStores().join("\n"));
    break;

  case "list": {
    const store = args[0] ?? await defaultStore();
    const entries = db.listEntries(store);
    if (entries.length === 0) {
      console.log(`No memories in "${store}".`);
    } else {
      for (const e of entries) {
        const parts = [`[${store}]`, e.label];
        if (e.branch) parts.push(`(branch:${e.branch})`);
        if (e.confidence) parts.push(`(c:${e.confidence})`);
        parts.push(`(${e.updated_at})`);
        console.log(parts.join(" "));
      }
    }
    break;
  }

  case "show": {
    if (!args[0]) usage();
    const label = args[0];
    const store = args[1] ?? await defaultStore();
    const entry = db.showEntry(store, label);
    if (!entry) {
      console.log(`No memory labeled "${label}" in "${store}".`);
    } else {
      console.log(`[${store}] ${entry.label}`);
      if (entry.branch) console.log(`branch: ${entry.branch}`);
      if (entry.confidence) console.log(`confidence: ${entry.confidence}`);
      console.log(`created: ${entry.created_at}  updated: ${entry.updated_at}`);
      console.log();
      // Strip the "# Label\n\n" heading that remember() prepends.
      const body = entry.content.replace(/^# .+\n\n/, "");
      console.log(body);
    }
    break;
  }

  case "forget": {
    if (!args[0]) usage();
    const label = args[0];
    const store = args[1] ?? await defaultStore();
    const ok = db.forgetEntry(store, label);
    console.log(ok ? `[forgotten] ${store} :: ${label}` : `No memory labeled "${label}" in "${store}".`);
    break;
  }

  case "search": {
    if (!args[0]) usage();
    if (args.length > 2) {
      console.error(`error: too many arguments — quote multi-word queries: thatch search "${args.join(" ")}"`);
      process.exit(1);
    }
    const query = args[0];
    const store = args[1] ?? await defaultStore();
    if (args[1] && store !== "all" && !db.listStores().includes(store)) {
      console.error(`error: no store named "${store}" (did you mean to quote the query?)`);
      console.error(`stores: ${db.listStores().join(", ")}`);
      process.exit(1);
    }
    const stores = store === "all" ? [await defaultStore(), "global"] : [store];

    console.error("Loading embedding model...");
    const model = new BgeEmbeddingModel();
    const queryEmb = await model.queryEmbed(query);
    const results = db.recall(stores, queryEmb, { limit: 10 });

    if (results.length === 0) {
      console.log(`No matches for "${query}" in [${stores.join(", ")}].`);
    } else {
      for (const r of results) {
        const score = r._score.toFixed(3);
        const branch = r.branch ? ` branch:${r.branch}` : "";
        const conf = r.confidence ? ` c:${r.confidence}` : "";
        console.log(`[score:${score}] [${r.store}${branch}${conf}] ${r.label}`);
      }
    }
    break;
  }

  case "mcp": {
    // The MCP server manages its own DB connection; close this one first.
    db.close();
    const { runMcpServer } = await import("../src/mcp");
    await runMcpServer();
    // runMcpServer blocks until stdin closes; don't fall through to db.close().
    process.exit(0);
  }

  case "reminder": {
    const isJson = args.includes("--json");
    const repo = await defaultStore();
    const worktree = projectDir();
    let hygiene: string | null = null;
    try {
      hygiene = await hygieneReport(db, repo, worktree);
    } catch (err) {
      console.error(`[thatch] hygiene report failed: ${err}`);
    }
    const reminder = claudeSessionStartReminder(repo, hygiene);
    if (isJson) {
      console.log(JSON.stringify({ additional_context: reminder }));
    } else {
      console.log(reminder);
    }
    break;
  }

  case "hygiene": {
    const repo = await defaultStore();
    const worktree = projectDir();
    const hygiene = await hygieneReport(db, repo, worktree);
    console.log(hygiene ?? "Store is healthy.");
    break;
  }

  case "prime": {
    const primerPrompt = "Load the thatch-project-primer skill and follow its instructions to prime this project's memory store.";
    const opencodeBin = Bun.which("opencode");
    const agentBin = Bun.which("agent");
    const claudeBin = Bun.which("claude");

    if (opencodeBin) {
      console.error("Priming project memory via opencode...");
      const proc = Bun.spawnSync([opencodeBin, "run", primerPrompt], {
        stdout: "inherit",
        stderr: "inherit",
      });
      process.exit(proc.exitCode ?? 1);
    } else if (agentBin) {
      // Cursor CLI: -p for non-interactive print mode, --approve-mcps to
      // auto-approve the thatch MCP server (no interactive UI in -p mode).
      console.error("Priming project memory via cursor agent...");
      const proc = Bun.spawnSync([agentBin, "-p", primerPrompt, "--approve-mcps"], {
        stdout: "inherit",
        stderr: "inherit",
      });
      process.exit(proc.exitCode ?? 1);
    } else if (claudeBin) {
      console.error("Priming project memory via claude...");
      const proc = Bun.spawnSync([claudeBin, primerPrompt], {
        stdout: "inherit",
        stderr: "inherit",
      });
      process.exit(proc.exitCode ?? 1);
    } else {
      console.error("Error: none of 'opencode', 'agent', or 'claude' found on PATH.");
      console.error("Install one of them to use thatch prime.");
      process.exit(1);
    }
    break;
  }

  case "setup": {
    const isGlobal = args.includes("--global");
    const isClaude = args.includes("--claude");
    const isCursor = args.includes("--cursor");

    if (!isClaude && !isCursor) {
      console.error("Specify at least one host: --claude and/or --cursor.");
      console.error("Usage: thatch setup --claude [--cursor] [--global]");
      process.exit(1);
    }

    // Resolve the thatch binary path for hooks and MCP config.
    // If `thatch` is on PATH (npm global install, opencode plugin install),
    // use the bare name — it survives updates and works across machines.
    // If not on PATH (local dev checkout), use the absolute path to this script.
    const thatchOnPath = Bun.which("thatch");
    const thatchBin = thatchOnPath ?? resolve(process.argv[1] ?? process.execPath);
    const dir = projectDir();

    if (isClaude) {
      const result = setupClaudeCode(thatchBin, isGlobal, dir);

      console.log(`Thatch setup complete for Claude Code (${isGlobal ? "global" : "project-local"}).`);
      console.log();
      if (result.mcpConfig) {
        console.log(`  MCP config:    ${result.mcpConfig}`);
      }
      console.log(`  Instructions:  ${result.claudeMd}`);
      console.log(`  Hooks:         ${result.settings}`);
      const skillsDir = result.skills[0]?.path
        ? result.skills[0].path.split("/").slice(0, -1).join("/")
        : "(no skills installed)";
      console.log(`  Skills:        ${skillsDir} (${result.skills.length} files)`);
      console.log();
      if (result.mcpAddCommand) {
        console.log("To register the MCP server globally, run:");
        console.log(`  ${result.mcpAddCommand}`);
        console.log();
      }
      console.log("Restart Claude Code for the changes to take effect.");
    }

    if (isCursor) {
      const result = setupCursor(thatchBin, isGlobal, dir);

      console.log();
      console.log(`Thatch setup complete for Cursor (${isGlobal ? "global" : "project-local"}).`);
      console.log();
      console.log(`  MCP config:    ${result.mcpConfig}`);
      console.log(`  Instructions:  ${result.agentsMd}`);
      console.log(`  Hooks:         ${result.hooks}`);
      const skillsDir = result.skills[0]?.path
        ? result.skills[0].path.split("/").slice(0, -1).join("/")
        : "(no skills installed)";
      console.log(`  Skills:        ${skillsDir} (${result.skills.length} files)`);
      console.log();
      console.log("Restart Cursor for the changes to take effect.");
    }
    break;
  }

  case "buffer-batch": {
    // PostToolBatch hook: append the batch's tool_calls to the session's
    // JSONL queue. Silent on success — no stdout — so the next model call
    // is not delayed waiting for an exit code-driven message.
    try {
      const raw = await Bun.stdin.text();
      const data = JSON.parse(raw) as { session_id?: string; tool_calls?: unknown[] };
      if (data.session_id && Array.isArray(data.tool_calls)) {
        const { appendBatch } = await import("../src/extract-queue");
        appendBatch(data.session_id, data.tool_calls as never);
      }
    } catch (err) {
      console.error(`[thatch buffer-batch] failed: ${err}`);
    }
    break;
  }

  case "buffer-tool": {
    // Cursor postToolUse hook: append a single tool interaction to the
    // session's JSONL queue. Cursor fires postToolUse per-tool (no batch
    // equivalent), so this receives one tool at a time. Silent on success.
    // Session ID comes as `conversation_id` in Cursor (vs `session_id` in
    // Claude Code). The tool result field name is not explicitly documented,
    // so we try the most likely candidates.
    try {
      const raw = await Bun.stdin.text();
      const data = JSON.parse(raw) as {
        conversation_id?: string;
        session_id?: string;
        tool_name?: string;
        tool_input?: Record<string, unknown>;
        tool_use_id?: string;
        tool_result?: string | unknown[];
        tool_response?: string | unknown[];
        result_json?: string;
        result?: string | unknown[];
        output?: string;
      };
      const sessionID = data.conversation_id ?? data.session_id;
      if (sessionID && data.tool_name) {
        const { appendBatch } = await import("../src/extract-queue");
        const response = data.tool_result ?? data.tool_response ?? data.result_json ?? data.result ?? data.output ?? "";
        appendBatch(sessionID, [{
          tool_name: data.tool_name,
          tool_input: data.tool_input ?? {},
          tool_use_id: data.tool_use_id,
          tool_response: response,
        }]);
      }
    } catch (err) {
      console.error(`[thatch buffer-tool] failed: ${err}`);
    }
    break;
  }

  case "flush-tools": {
    // UserPromptSubmit (Claude Code) / beforeSubmitPrompt (Cursor) hook.
    // Three priority tiers:
    //   1. Extraction nudge — buffered tool interactions are queued for fact
    //      extraction (carries the JSON payload for thatch-fact-extractor).
    //   2. Recall nudge — the user's prompt semantically matches existing
    //      memories. Uses the sideband socket to ask the warm MCP server to
    //      embed the prompt and search, avoiding a cold model load here.
    //   3. Write nudge — static "did you learn anything?" fallback for
    //      conversational turns with no tool use and no memory matches.
    // --json wraps output as { additional_context: "..." } for Cursor hooks.
    // Without --json, stdout is plain text (Claude Code style).
    const isJson = args.includes("--json");
    try {
      const raw = await Bun.stdin.text();
      const data = JSON.parse(raw) as {
        session_id?: string;
        conversation_id?: string;
        prompt?: string;
        message?: string;
        text?: string;
        user_input?: string;
        input?: string;
      };
      const sessionID = data.session_id ?? data.conversation_id;

      const { peekQueue, getMissedCount, incrementMissedCount } = await import("../src/extract-queue");
      const { buildExtractionPayload } = await import("../src/extraction");
      const { extractionNudge, claudeWriteNudge, claudeRecallNudge, predictionNudge } = await import("../src/prompts");

      let repo = "unknown";
      try { repo = await detectRepo(); } catch {}

      // Tier 1: extraction nudge. Peek (don't drain) — the queue persists
      // until the agent calls memory_remember, which triggers consumeQueue.
      // If the agent ignores the nudge, the payload grows on the next flush.
      const interactions = sessionID ? peekQueue(sessionID) : [];
      if (interactions.length > 0) {
        const missed = sessionID ? getMissedCount(sessionID) : 0;
        if (sessionID) incrementMissedCount(sessionID);
        const output = extractionNudge(interactions.length, missed, "mcp__thatch__memory_remember", buildExtractionPayload(interactions, repo));
        if (isJson) console.log(JSON.stringify({ additional_context: output }));
        else console.log(output);
        break;
      }

      // Tier 2: recall nudge + prediction fire via sideband. The prompt text
      // field name varies by host (Claude Code: "prompt", Cursor: undocumented).
      // Both recall and predictions share the same sideband round-trip.
      const promptText = data.prompt ?? data.message ?? data.text ?? data.user_input ?? data.input;
      if (promptText && promptText.length >= 10) {
        const { sidebandMatch, sidebandPredictions, sidebandSocketPath } = await import("../src/sideband");
        const sockPath = sidebandSocketPath(dbPath);
        const recallThreshold = parseFloat(process.env.THATCH_RECALL_THRESHOLD ?? "0.55");
        const predThreshold = parseFloat(process.env.THATCH_PREDICTION_THRESHOLD ?? "0.45");

        const [matches, predictions] = await Promise.all([
          sidebandMatch(sockPath, promptText, [repo, "global"], recallThreshold, 5),
          sidebandPredictions(sockPath, promptText, [repo, "global"], predThreshold, 5),
        ]);

        const parts: string[] = [];
        if (matches && matches.length > 0) {
          parts.push(claudeRecallNudge(matches));
        }
        if (predictions && predictions.length > 0) {
          parts.push(predictionNudge(predictions));
        }

        if (parts.length > 0) {
          const output = parts.join("\n\n");
          if (isJson) console.log(JSON.stringify({ additional_context: output }));
          else console.log(output);
          break;
        }
      }

      // Tier 3: static write nudge.
      const output = claudeWriteNudge();
      if (isJson) console.log(JSON.stringify({ additional_context: output }));
      else console.log(output);
    } catch (err) {
      console.error(`[thatch flush-tools] failed: ${err}`);
      try {
        const { claudeWriteNudge } = await import("../src/prompts");
        const fallback = claudeWriteNudge();
        if (isJson) {
          console.log(JSON.stringify({ additional_context: fallback }));
        } else {
          console.log(fallback);
        }
      } catch {
        // If even the fallback import fails, do nothing — silent failure is
        // preferable to blocking the user's prompt over an unrelated hook.
      }
    }
    break;
  }

  case "flush-predictions": {
    // UserPromptSubmit (Claude Code) / beforeSubmitPrompt (Cursor) hook.
    // Standalone prediction fire: queries the sideband for scored
    // predictions matching the prompt text, prints the prediction nudge
    // if any matchers fire. --json wraps as { additional_context: "..." }
    // for Cursor hooks. Without --json, stdout is plain text.
    //
    // NOTE: flush-tools already fires predictions alongside the recall
    // nudge in its tier 2 block. This subcommand exists for testing and
    // for hosts that want prediction-only output without the recall or
    // extraction nudges.
    const isJson = args.includes("--json");
    try {
      const raw = await Bun.stdin.text();
      const data = JSON.parse(raw) as {
        prompt?: string;
        message?: string;
        text?: string;
        user_input?: string;
        input?: string;
      };

      const promptText = data.prompt ?? data.message ?? data.text ?? data.user_input ?? data.input;
      if (!promptText || promptText.length < 10) {
        if (isJson) console.log(JSON.stringify({ additional_context: "" }));
        break;
      }

      let repo = "unknown";
      try { repo = await detectRepo(); } catch {}

      const { sidebandPredictions, sidebandSocketPath } = await import("../src/sideband");
      const { predictionNudge } = await import("../src/prompts");
      const sockPath = sidebandSocketPath(dbPath);
      const threshold = parseFloat(process.env.THATCH_PREDICTION_THRESHOLD ?? "0.45");
      const predictions = await sidebandPredictions(sockPath, promptText, [repo, "global"], threshold, 5);

      if (predictions && predictions.length > 0) {
        const output = predictionNudge(predictions);
        if (isJson) console.log(JSON.stringify({ additional_context: output }));
        else console.log(output);
      } else {
        if (isJson) console.log(JSON.stringify({ additional_context: "" }));
      }
    } catch (err) {
      console.error(`[thatch flush-predictions] failed: ${err}`);
    }
    break;
  }

  default:
    usage();
}

db.close();
