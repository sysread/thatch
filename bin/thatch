#!/usr/bin/env bun

import { homedir } from "node:os";
import { join, resolve } from "node:path";
import { ThatchDB } from "../src/db";
import { detectRepo } from "../src/git";
import { BgeEmbeddingModel } from "../src/embeddings";
import { hygieneReport } from "../src/hygiene";
import { claudeSessionStartReminder } from "../src/prompts";
import { setupClaudeCode } from "../src/setup";

const configHome = process.env.XDG_CONFIG_HOME ?? join(homedir(), ".config");
const dbPath = process.env.THATCH_DB_PATH ?? join(configHome, "thatch", "thatch.db");
const db = new ThatchDB(dbPath);

const [command, ...args] = process.argv.slice(2);

function usage(): never {
  console.error(`USAGE
  thatch stores                    List all stores
  thatch list   [store]            List memory labels in a store  
  thatch show   <label> [store]    Display a memory by label
  thatch forget <label> [store]    Remove a memory by label
  thatch search <query> [store]    Semantic search (cosine similarity)
  thatch mcp                       Start the stdio MCP server (for Claude Code)
  thatch reminder                  Print session-start reminder (for SessionStart hook)
  thatch hygiene                   Print the hygiene report (standalone)
  thatch prime                     Prime project memory (runs the primer skill via opencode or claude)
  thatch buffer-batch              Append a PostToolBatch payload to the queue (hook only)
  thatch flush-tools               Drain the queue + print an extraction nudge (hook only)
  thatch setup [--claude] [--global] [--force]
                                   Install config + instructions + hooks + skills

Stores default to the repo detected from git remote. Use "global" for the
global store. Use "all" with search to search project + global together.`);
  process.exit(1);
}

async function defaultStore(): Promise<string> {
  try {
    return await detectRepo();
  } catch {
    return "unknown";
  }
}

switch (command) {
  case "stores":
    console.log(db.listStores().join("\n"));
    break;

  case "list": {
    const store = args[0] ?? await defaultStore();
    const entries = db.listEntries(store);
    if (entries.length === 0) {
      console.log(`No memories in "${store}".`);
    } else {
      for (const e of entries) {
        const parts = [`[${store}]`, e.label];
        if (e.branch) parts.push(`(branch:${e.branch})`);
        if (e.confidence) parts.push(`(c:${e.confidence})`);
        parts.push(`(${e.updated_at})`);
        console.log(parts.join(" "));
      }
    }
    break;
  }

  case "show": {
    if (!args[0]) usage();
    const label = args[0];
    const store = args[1] ?? await defaultStore();
    const entry = db.showEntry(store, label);
    if (!entry) {
      console.log(`No memory labeled "${label}" in "${store}".`);
    } else {
      console.log(`[${store}] ${entry.label}`);
      if (entry.branch) console.log(`branch: ${entry.branch}`);
      if (entry.confidence) console.log(`confidence: ${entry.confidence}`);
      console.log(`created: ${entry.created_at}  updated: ${entry.updated_at}`);
      console.log();
      // Strip the "# Label\n\n" heading that remember() prepends.
      const body = entry.content.replace(/^# .+\n\n/, "");
      console.log(body);
    }
    break;
  }

  case "forget": {
    if (!args[0]) usage();
    const label = args[0];
    const store = args[1] ?? await defaultStore();
    const ok = db.forgetEntry(store, label);
    console.log(ok ? `[forgotten] ${store} :: ${label}` : `No memory labeled "${label}" in "${store}".`);
    break;
  }

  case "search": {
    if (!args[0]) usage();
    if (args.length > 2) {
      console.error(`error: too many arguments — quote multi-word queries: thatch search "${args.join(" ")}"`);
      process.exit(1);
    }
    const query = args[0];
    const store = args[1] ?? await defaultStore();
    if (args[1] && store !== "all" && !db.listStores().includes(store)) {
      console.error(`error: no store named "${store}" (did you mean to quote the query?)`);
      console.error(`stores: ${db.listStores().join(", ")}`);
      process.exit(1);
    }
    const stores = store === "all" ? [await defaultStore(), "global"] : [store];

    console.error("Loading embedding model...");
    const model = new BgeEmbeddingModel();
    const queryEmb = await model.queryEmbed(query);
    const results = db.recall(stores, queryEmb, { limit: 10 });

    if (results.length === 0) {
      console.log(`No matches for "${query}" in [${stores.join(", ")}].`);
    } else {
      for (const r of results) {
        const score = r._score.toFixed(3);
        const branch = r.branch ? ` branch:${r.branch}` : "";
        const conf = r.confidence ? ` c:${r.confidence}` : "";
        console.log(`[score:${score}] [${r.store}${branch}${conf}] ${r.label}`);
      }
    }
    break;
  }

  case "mcp": {
    // The MCP server manages its own DB connection; close this one first.
    db.close();
    const { runMcpServer } = await import("../src/mcp");
    await runMcpServer();
    // runMcpServer blocks until stdin closes; don't fall through to db.close().
    process.exit(0);
  }

  case "reminder": {
    const repo = await defaultStore();
    const worktree = process.env.CLAUDE_PROJECT_DIR ?? process.cwd();
    let hygiene: string | null = null;
    try {
      hygiene = await hygieneReport(db, repo, worktree);
    } catch (err) {
      console.error(`[thatch] hygiene report failed: ${err}`);
    }
    console.log(claudeSessionStartReminder(repo, hygiene));
    break;
  }

  case "hygiene": {
    const repo = await defaultStore();
    const worktree = process.env.CLAUDE_PROJECT_DIR ?? process.cwd();
    const hygiene = await hygieneReport(db, repo, worktree);
    console.log(hygiene ?? "Store is healthy.");
    break;
  }

  case "prime": {
    const primerPrompt = "Load the thatch-project-primer skill and follow its instructions to prime this project's memory store.";
    const opencodeBin = Bun.which("opencode");
    const claudeBin = Bun.which("claude");

    if (opencodeBin) {
      console.error("Priming project memory via opencode...");
      const proc = Bun.spawnSync([opencodeBin, "run", primerPrompt], {
        stdout: "inherit",
        stderr: "inherit",
      });
      process.exit(proc.exitCode ?? 1);
    } else if (claudeBin) {
      console.error("Priming project memory via claude...");
      const proc = Bun.spawnSync([claudeBin, primerPrompt], {
        stdout: "inherit",
        stderr: "inherit",
      });
      process.exit(proc.exitCode ?? 1);
    } else {
      console.error("Error: neither 'opencode' nor 'claude' found on PATH.");
      console.error("Install one of them to use thatch prime.");
      process.exit(1);
    }
    break;
  }

  case "setup": {
    const isGlobal = args.includes("--global");
    const isClaude = args.includes("--claude");

    if (!isClaude) {
      console.error("Currently only --claude is supported.");
      console.error("Usage: thatch setup --claude [--global]");
      process.exit(1);
    }

    // Resolve the thatch binary path for hooks and MCP config.
    // If `thatch` is on PATH (npm global install, opencode plugin install),
    // use the bare name — it survives updates and works across machines.
    // If not on PATH (local dev checkout), use the absolute path to this script.
    const thatchOnPath = Bun.which("thatch");
    const thatchBin = thatchOnPath ?? resolve(process.argv[1] ?? process.execPath);
    const projectDir = process.env.CLAUDE_PROJECT_DIR ?? process.cwd();

    const result = setupClaudeCode(thatchBin, isGlobal, projectDir);

    console.log(`Thatch setup complete (${isGlobal ? "global" : "project-local"}).`);
    console.log();
    if (result.mcpConfig) {
      console.log(`  MCP config:    ${result.mcpConfig}`);
    }
    console.log(`  Instructions:  ${result.claudeMd}`);
    console.log(`  Hooks:         ${result.settings}`);
    // Skills dir is not currently surfaced on SetupResult — derive it from
    // the skills file paths (they all share the same parent directory).
    const skillsDir = result.skills[0]?.path
      ? result.skills[0].path.split("/").slice(0, -1).join("/")
      : "(no skills installed)";
    console.log(`  Skills:        ${skillsDir} (${result.skills.length} files)`);
    console.log();
    if (result.mcpAddCommand) {
      console.log("To register the MCP server globally, run:");
      console.log(`  ${result.mcpAddCommand}`);
      console.log();
    }
    console.log("Restart Claude Code for the changes to take effect.");
    break;
  }

  case "buffer-batch": {
    // PostToolBatch hook: append the batch's tool_calls to the session's
    // JSONL queue. Silent on success — no stdout — so the next model call
    // is not delayed waiting for an exit code-driven message.
    try {
      const raw = await Bun.stdin.text();
      const data = JSON.parse(raw) as { session_id?: string; tool_calls?: unknown[] };
      if (data.session_id && Array.isArray(data.tool_calls)) {
        const { appendBatch } = await import("../src/extract-queue");
        appendBatch(data.session_id, data.tool_calls as never);
      }
    } catch (err) {
      console.error(`[thatch buffer-batch] failed: ${err}`);
    }
    break;
  }

  case "flush-tools": {
    // UserPromptSubmit hook: drain the queue. With buffered interactions,
    // print the extraction nudge carrying the payload so the agent can load
    // the thatch-fact-extractor skill and persist durable facts. With an
    // empty queue, fall back to the static write-nudge so the original
    // workflow contract (a per-prompt "did you learn anything?" reminder)
    // is preserved on conversational turns that did no tool use.
    try {
      const raw = await Bun.stdin.text();
      const data = JSON.parse(raw) as { session_id?: string };

      const { flushQueue } = await import("../src/extract-queue");
      const { buildExtractionPayload } = await import("../src/extraction");
      const { claudeExtractionNudge, claudeWriteNudge } = await import("../src/prompts");

      let repo = "unknown";
      try { repo = await detectRepo(); } catch {}

      const interactions = data.session_id ? flushQueue(data.session_id) : [];
      if (interactions.length > 0) {
        console.log(claudeExtractionNudge(interactions.length, buildExtractionPayload(interactions, repo)));
      } else {
        console.log(claudeWriteNudge());
      }
    } catch (err) {
      console.error(`[thatch flush-tools] failed: ${err}`);
      try {
        const { claudeWriteNudge } = await import("../src/prompts");
        console.log(claudeWriteNudge());
      } catch {
        // If even the fallback import fails, do nothing — silent failure is
        // preferable to blocking the user's prompt over an unrelated hook.
      }
    }
    break;
  }

  default:
    usage();
}

db.close();
