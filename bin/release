#!/usr/bin/env bash
set -euo pipefail

v="${1:?usage: $0 patch|minor|major}"

case "$v" in patch|minor|major) ;; *)
  echo "error: expected patch, minor, or major; got '$v'"
  exit 1
esac

curr=$(node -p "require('./package.json').version")
next=$(node -e "
  const [maj, min, pat] = '$curr'.split('.').map(Number);
  if ('$v' === 'major')  console.log((maj+1)+'.0.0');
  else if ('$v' === 'minor') console.log(maj+'.'+(min+1)+'.0');
  else console.log(maj+'.'+min+'.'+(pat+1));
")

echo "thatch release"
echo "  current: $curr"
echo "  bump:    $v"
echo "  next:    $next"
echo

# Pre-flight: verify the current version is published on npm before allowing a
# new release. A tagged-but-unpublished version means the prior publish failed;
# stacking another release on top hides the gap and complicates recovery.
if git rev-parse -q --verify "refs/tags/v$curr" >/dev/null 2>&1; then
  pub_status=$(npm view "@jeffober/thatch@$curr" version 2>&1 || true)
  if ! echo "$pub_status" | grep -q "^$curr$"; then
    if echo "$pub_status" | grep -q "E404"; then
      echo "ERROR: v$curr is tagged but not published to npm."
      echo "  The previous release failed. Check: gh run view --workflow=publish.yml"
      echo "  Fix the workflow, delete and re-tag v$curr, push, then re-run this release."
      echo "  To re-tag: git tag -d v$curr && git tag v$curr <commit> && git push origin :refs/tags/v$curr && git push origin v$curr"
      exit 1
    else
      echo "WARN: npm registry check failed (not a 404 — may be a network issue or npm outage):"
      echo "  $pub_status"
      echo "  Proceeding anyway. Verify v$curr is published before relying on this."
      echo
    fi
  fi
fi

echo "▸ running checks (typecheck + tests + markdown lint)..."
mise run check
echo "  ✓ checks passed"
echo

echo "▸ bumping version..."
npm version "$v" --no-git-tag-version 2>/dev/null
echo "  ✓ package.json: $next"
echo

read -p "▸ commit, tag, and push v$next? [y/N] " -r
echo
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
  echo "aborted — reverting package.json"
  git checkout package.json
  exit 0
fi

git add package.json
git commit -m "v$next"
git tag "v$next"
echo "  ✓ committed and tagged v$next"
echo

echo "▸ pushing..."
git push
git push --tags
echo "  ✓ pushed"
echo

echo "done — CI will publish v$next to npm"